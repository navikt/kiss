# ──────────────────────────────────────
# KISS – Environment Variables
# ──────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── Database ──
# Docker Compose (default):
DATABASE_URL=postgresql://kiss:kiss@localhost:5432/kiss
# Postgres.app (uncomment and adjust username):
# DATABASE_URL=postgresql://localhost:5432/kiss

# ── Storage ──
# "local" = filesystem (.local-storage/), "gcs" = Google Cloud Storage
# Default: "local" in development, "gcs" in production
STORAGE_PROVIDER=local

# Required when STORAGE_PROVIDER=gcs
# GCS_BUCKET_NAME=kiss-data

# ── Azure AD (not needed for local dev without auth) ──
# AZURE_OPENID_CONFIG_JWKS_URI=
# AZURE_APP_CLIENT_ID=
# AZURE_APP_CLIENT_SECRET=
# AZURE_OPENID_CONFIG_TOKEN_ENDPOINT=

# ── Authorization (Azure AD group IDs, comma-separated) ──
# KISS_ADMIN_GROUP_IDS=
# KISS_AUDITOR_GROUP_IDS=

# ── Local dev user (overrides Azure AD auth when set) ──
# Set these to simulate a logged-in user during local development.
# LOCAL_DEV_USER is the NAV ident (e.g. "A123456").
# LOCAL_DEV_GROUPS should match KISS_ADMIN_GROUP_IDS / KISS_AUDITOR_GROUP_IDS to test roles.
LOCAL_DEV_USER=A123456
LOCAL_DEV_NAME=Kari Nordmann
LOCAL_DEV_EMAIL=kari.nordmann@nav.no
LOCAL_DEV_GROUPS=kiss-admin

# ── Nais API (for scanning applications) ──
# URL for Nais Console GraphQL API.
# For local development, run `nais alpha api proxy` and use the local proxy:
NAIS_API_URL=http://localhost:4242/graphql

# Token for authenticating with Nais Console API (production).
# Not needed when using local proxy (`nais alpha api proxy`).
# NAIS_API_TOKEN=

# Enable periodic Nais scanning (every 5 min). Set to "true" to activate.
# Safe for multiple pods — uses PostgreSQL advisory locks to prevent duplicates.
ENABLE_NAIS_SYNC=true

# ── Feature Flags ──
# Show compliance statistics (percentages, progress bars, implementation counts).
# Set to "false" to hide stats while rulesets and routines are being defined.
SHOW_COMPLIANCE_STATS=true
