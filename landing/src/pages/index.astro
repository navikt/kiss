---
import Base from "../layouts/Base.astro"

const base = import.meta.env.BASE_URL
const appUrl = "https://kiss.ansatt.nav.no"
const repoUrl = "https://github.com/navikt/kiss"
const storybookUrl = `${base}storybook/`

const title = "KISS · Kontrollrammeverk for sikker systemutvikling i Nav"
const description =
	"KISS samler kontrollrammeverket, compliance-vurderingene og rapportene for sikker systemutvikling i Nav på ett sted, slik at det blir enkelt å vise at vi har kontroll."
---

<Base title={title} description={description}>
	<header class="site-header">
		<div class="wrap">
			<a class="brand-mark" href={base} aria-label="KISS, til toppen">
				<img src={`${base}logo.png`} alt="" width="36" height="36" />
				<span>KISS</span>
			</a>
			<nav class="site-nav" aria-label="Hovedmeny">
				<a class="nav-text" href="#verdi">Hvorfor</a>
				<a class="nav-text" href="#slik">Slik funker det</a>
				<a class="nav-text" href="#integrasjoner">Integrasjoner</a>
				<a class="nav-text" href="#oversikt">For ledere og revisjon</a>
				<a class="nav-text" href="#utvikling">For utviklere</a>
				<a class="nav-cta" href={appUrl}>Åpne KISS</a>
			</nav>
		</div>
	</header>

	<main id="hovedinnhold">
		<!-- Hero -->
		<section class="hero" aria-labelledby="hero-tittel">
			<div class="wrap">
				<p class="eyebrow">Internkontroll for systemutvikling</p>
				<h1 id="hero-tittel">Vis at Nav har kontroll på sikker systemutvikling</h1>
				<p class="lead">
					KISS samler kontrollrammeverket, vurderingene per applikasjon og rapportene på ett
					sted. Da blir det lett å gjøre rett, og lett å se hvor vi står.
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href={appUrl}>
						Åpne KISS
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
							><path
								d="M5 12h14M13 6l6 6-6 6"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"></path></svg
						>
					</a>
					<a class="btn btn-secondary" href={repoUrl}>Se kildekoden</a>
				</div>
				<p class="access-note">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
						><path
							d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Z"
							stroke="currentColor"
							stroke-width="2"
							stroke-linejoin="round"></path></svg
					>
					<span>
						KISS er et internt verktøy. Du logger inn med Nav-konto via Azure AD, og ser
						status og rapporter for seksjonene du har tilgang til.
					</span>
				</p>
			</div>
		</section>

		<!-- Hvorfor / verdi -->
		<section id="verdi" aria-labelledby="verdi-tittel">
			<div class="wrap">
				<div class="section-intro">
					<p class="eyebrow">Hvorfor KISS</p>
					<h2 id="verdi-tittel">Oversikt uten ekstra papirarbeid</h2>
					<p>
						Sikker systemutvikling handler om mange små valg i hverdagen. KISS samler dem så
						de henger sammen, og lar hver seksjon følge med på sin egen status.
					</p>
				</div>
				<div class="card-grid">
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><path
									d="M4 5h16M4 12h16M4 19h10"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"></path></svg
							>
						</span>
						<h3>Ett sted for rammeverket</h3>
						<p>
							Domener, risikoer og kontroller fra Navs kontrollrammeverk importeres og holdes
							oppdatert, så alle jobber ut fra samme grunnlag.
						</p>
					</article>
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><path
									d="m5 13 4 4L19 7"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<h3>Vurdering der arbeidet skjer</h3>
						<p>
							De som kjenner applikasjonen best svarer ut hvordan den følger kontrollene.
							Hver vurdering lagres med historikk.
						</p>
					</article>
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"
								></circle><path
									d="m20 20-3.5-3.5"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"></path></svg
							>
						</span>
						<h3>Nye applikasjoner kommer med</h3>
						<p>
							Applikasjoner på Nais-plattformen oppdages automatisk og knyttes til riktig
							team og seksjon, så ingen blir glemt.
						</p>
					</article>
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><path
									d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"
									stroke="currentColor"
									stroke-width="2"
									stroke-linejoin="round"></path><path
									d="M13 3v6h6"
									stroke="currentColor"
									stroke-width="2"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<h3>Rapporter når noen spør</h3>
						<p>
							Generer status per seksjon eller på tvers, klart til å deles med ledelse og
							revisjon uten ekstra runder med innsamling.
						</p>
					</article>
				</div>
			</div>
		</section>

		<!-- Slik funker det -->
		<section id="slik" aria-labelledby="slik-tittel">
			<div class="wrap">
				<div class="section-intro">
					<p class="eyebrow">Slik funker det</p>
					<h2 id="slik-tittel">Fra rammeverk til status i fire steg</h2>
					<p>
						Veien fra retningslinje til synlig oversikt er kort. Hvert steg bygger på det
						forrige.
					</p>
				</div>
				<ol class="flow">
					<li>
						<h3>Rammeverket kommer inn</h3>
						<p>
							Navs kontrollrammeverk importeres og blir til domener, risikoer og kontroller
							du kan navigere i.
						</p>
					</li>
					<li>
						<h3>Applikasjonene kobles på</h3>
						<p>
							Applikasjoner hentes fra Nais og knyttes til riktig team og seksjon, helt av seg
							selv.
						</p>
					</li>
					<li>
						<h3>Vurderingen gjøres</h3>
						<p>
							De ansvarlige svarer ut hvordan hver applikasjon oppfyller kontrollene, i sitt
							eget tempo.
						</p>
					</li>
					<li>
						<h3>Statusen blir synlig</h3>
						<p>
							Dashboard og rapporter viser hvor Nav står, både for det enkelte teamet og på
							tvers.
						</p>
					</li>
				</ol>
			</div>
		</section>

		<!-- Mindre rutinearbeid / integrasjoner -->
		<section id="integrasjoner" aria-labelledby="integrasjoner-tittel">
			<div class="wrap">
				<div class="section-intro">
					<p class="eyebrow">Mindre rutinearbeid</p>
					<h2 id="integrasjoner-tittel">Bevis og rutiner rett fra kildesystemene</h2>
					<p>
						Mye av compliance-arbeidet handler om å hente dokumentasjon fra andre systemer.
						KISS kobler seg på kildene, så du slipper å samle det manuelt og kan bruke tiden
						på selve vurderingen.
					</p>
				</div>
				<div class="card-grid">
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><path
									d="M12 3v12m0 0 4-4m-4 4-4-4M5 17v2a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<h3>Bevis hentes direkte</h3>
						<p>
							Revisjonsbevis som tilgangs-, rolle- og brukeroversikter hentes fra
							kildesystemene og lagres i KISS, klart til gjennomgang. Da slipper du runden med
							e-post og vedlegg.
						</p>
					</article>
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><path
									d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"
									stroke="currentColor"
									stroke-width="2"
									stroke-linejoin="round"></path><circle
									cx="12"
									cy="12"
									r="3"
									stroke="currentColor"
									stroke-width="2"></circle></svg
							>
						</span>
						<h3>Fire-øyne-kontroll på leveranser</h3>
						<p>
							Gjennom <a href="https://navikt.github.io/nda">NDA</a> ser du at hver leveranse er
							godkjent av minst to personer, og hva endringen gjelder. KISS henter dette som
							bevis, så kravet er dokumentert uten ekstra arbeid.
						</p>
					</article>
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><path
									d="M4 6h16M4 12h16M4 18h10"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"></path><path
									d="m17 17 2 2 3-3"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<h3>Faste gjennomganger fylles ut for deg</h3>
						<p>
							Tilbakevendende gjennomganger seedes med data fra kildesystemet, og KISS
							markerer hva som er nytt eller borte siden sist. Du vurderer endringene i stedet
							for å starte på nytt hver gang.
						</p>
					</article>
					<article class="card">
						<span class="card-icon" aria-hidden="true">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none"
								><circle cx="6" cy="6" r="2.5" stroke="currentColor" stroke-width="2"
								></circle><circle cx="18" cy="6" r="2.5" stroke="currentColor" stroke-width="2"
								></circle><circle cx="12" cy="18" r="2.5" stroke="currentColor" stroke-width="2"
								></circle><path
									d="M6 8.5V11a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8.5M12 13v2.5"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<h3>Kobler seg på det Nav allerede bruker</h3>
						<p>
							Integrasjoner mot Nais, Entra ID, GitHub, NDA og revisjonssystemene gjør at
							oversikten holder seg oppdatert, uten dobbeltregistrering.
						</p>
					</article>
				</div>
			</div>
		</section>

		<!-- For ledere og revisjon -->
		<section id="oversikt" aria-labelledby="oversikt-tittel">
			<div class="wrap split">
				<div class="section-intro">
					<p class="eyebrow">For ledere og revisjon</p>
					<h2 id="oversikt-tittel">Status du kan stole på</h2>
					<p>
						Teknologiledere ser hvordan egen seksjon ligger an. Revisjon og internkontroll
						henter status og rapporter for sine seksjoner, uten å vente på en manuell
						rapportrunde.
					</p>
				</div>
				<ul class="feature-list">
					<li>
						<span class="check" aria-hidden="true">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none"
								><path
									d="m5 13 4 4L19 7"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<span>
							<strong>Dashboard på flere nivåer</strong>
							Overordnet SDLC-status med dashboard for seksjon og team, så du finner raskt det som
							trenger oppmerksomhet.
						</span>
					</li>
					<li>
						<span class="check" aria-hidden="true">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none"
								><path
									d="m5 13 4 4L19 7"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<span>
							<strong>Rapporter på forespørsel</strong>
							Generer compliance-rapporter per seksjon eller samlet. Rapportene lagres trygt og
							kan hentes igjen senere.
						</span>
					</li>
					<li>
						<span class="check" aria-hidden="true">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none"
								><path
									d="m5 13 4 4L19 7"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<span>
							<strong>Sporbarhet og historikk</strong>
							Vurderinger lagres med historikk, og bevis kan hentes fra kildesystemer, så
							grunnlaget bak en status alltid er tilgjengelig.
						</span>
					</li>
					<li>
						<span class="check" aria-hidden="true">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none"
								><path
									d="m5 13 4 4L19 7"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"></path></svg
							>
						</span>
						<span>
							<strong>Lesetilgang for revisjon</strong>
							Revisjon og internkontroll ser status og henter rapporter for seksjonene de har
							tilgang til, styrt via Azure AD-grupper.
						</span>
					</li>
				</ul>
			</div>
		</section>

		<!-- For utviklere -->
		<section id="utvikling" aria-labelledby="utvikling-tittel">
			<div class="wrap split">
				<div class="section-intro">
					<p class="eyebrow">For utviklere</p>
					<h2 id="utvikling-tittel">Åpen kildekode, kjent verktøykasse</h2>
					<p>
						KISS er bygget på Navs vanlige plattform og designsystem. Du kan lese koden,
						kjøre den lokalt og bidra på den måten som passer deg.
					</p>
					<div class="tag-row">
						<span class="tag">React Router 7</span>
						<span class="tag">React 19</span>
						<span class="tag">Aksel</span>
						<span class="tag">TypeScript</span>
						<span class="tag">Drizzle ORM</span>
						<span class="tag">PostgreSQL 18</span>
						<span class="tag">Nais</span>
					</div>
					<ul class="feature-list" style="margin-top: var(--space-32)">
						<li>
							<span class="check" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none"
									><path
										d="m5 13 4 4L19 7"
										stroke="currentColor"
										stroke-width="2.2"
										stroke-linecap="round"
										stroke-linejoin="round"></path></svg
								>
							</span>
							<span>
								<strong>Lesetilgang til alt</strong>
								Koden ligger åpent på GitHub under MIT-lisens. Komponentene kan utforskes i
								Storybook.
							</span>
						</li>
						<li>
							<span class="check" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none"
									><path
										d="m5 13 4 4L19 7"
										stroke="currentColor"
										stroke-width="2.2"
										stroke-linecap="round"
										stroke-linejoin="round"></path></svg
								>
							</span>
							<span>
								<strong>Sporbare integrasjoner</strong>
								Utgående kall logges strukturert, så det er enkelt å se hva KISS snakker med og
								hvordan det går.
							</span>
						</li>
					</ul>
				</div>
				<div>
					<h3>Kom i gang lokalt</h3>
					<pre class="codeblock"><code><span class="c"># Hent avhengigheter</span>
pnpm install

<span class="c"># Start Postgres og push schema</span>
pnpm dev:setup

<span class="c"># Kjør utviklingsserveren</span>
pnpm dev</code></pre>
					<p style="margin-top: var(--space-16); color: var(--text-subtle)">
						Full oppskrift, miljøvariabler og databasevalg ligger i
						<a href={`${repoUrl}#utvikling`}>README</a>. Foretrekker du Postgres.app fremfor
						Docker, finnes det et eget oppsett der.
					</p>
					<p style="margin-top: var(--space-16)">
						<a class="btn btn-secondary" href={storybookUrl}>Utforsk komponentene i Storybook</a>
					</p>
				</div>
			</div>
		</section>

		<!-- CTA-bånd -->
		<section class="cta-band" aria-labelledby="cta-tittel">
			<div class="wrap">
				<h2 id="cta-tittel">Vil du se hvor Nav står?</h2>
				<p>
					Logg inn for å følge din egen seksjon, eller les koden bak. Begge deler er bare et
					klikk unna.
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href={appUrl}>Åpne KISS</a>
					<a class="btn btn-secondary" href={repoUrl}>Se kildekoden</a>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="wrap">
			<div>
				<a class="brand-mark" href={base} style="color: var(--brand-ink)" aria-label="KISS">
					<img src={`${base}logo.png`} alt="" width="32" height="32" />
					<span>KISS</span>
				</a>
				<p class="muted" style="margin-top: var(--space-12)">
					Kontrollrammeverk for Integrert Sikker Systemutvikling. Åpen kildekode under
					MIT-lisens, laget i Nav.
				</p>
			</div>
			<nav aria-label="Ressurser">
				<h2>Ressurser</h2>
				<ul>
					<li><a href={appUrl}>Åpne KISS</a></li>
					<li><a href={repoUrl}>Kildekode på GitHub</a></li>
					<li><a href={storybookUrl}>Komponenter i Storybook</a></li>
					<li><a href={`${repoUrl}/blob/main/LICENSE.md`}>MIT-lisens</a></li>
					<li><a href="https://aksel.nav.no">Aksel designsystem</a></li>
				</ul>
			</nav>
		</div>
	</footer>
</Base>
